  "item": [
    {
      "name": "Create account",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register returns a successful status', function () {",
              "    pm.expect(pm.response.code).to.be.within(200, 299);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"test{{$timestamp}}@example.com\",\n  \"password\": \"Password123!\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        },
        "description": "Smoke-check request for account registration. Role defaults to viewer."
      },
      "response": []
    },
    {
      "name": "Login and get token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login returns a successful status', function () {",
              "    pm.expect(pm.response.code).to.be.within(200, 299);",
              "});",
              "",
              "let jsonData = {};",
              "try {",
              "    jsonData = pm.response.json();",
              "} catch (e) {",
              "    jsonData = {};",
              "}",
              "",
              "const token = jsonData.token || jsonData.accessToken || jsonData.data?.token || jsonData.data?.accessToken || jsonData.user?.token;",
              "if (token) {",
              "    pm.environment.set('token', token);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"viewer@example.com\",\n  \"password\": \"Password123!\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Smoke-check login request. Stores a returned token into the collection variable token when present in the response."
      },
      "response": []
    },
